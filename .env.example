# ==============================
# AffiliateEngine Backend Config
# ==============================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/affiliateengine?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_chars_long
JWT_REFRESH_EXPIRES_IN=30d

# Gmail SMTP (Nodemailer)
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password

# Email Settings
EMAIL_FROM_NAME=AffiliateEngine
EMAIL_FROM_ADDRESS=noreply@affiliateengine.com

# OTP Settings
OTP_EXPIRES_MINUTES=10
OTP_LENGTH=6

# App URL (used in email links)
APP_URL=https://your-app.onrender.com
FRONTEND_URL=https://your-frontend.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
